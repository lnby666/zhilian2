    function renderSandbox() {
        const html = `<h2>🧪 深度沙盒模拟 · AI路径优化</h2><div class="card"><div class="slider-group"><label>上海港拥堵系数 (0~1): <span id="congVal">0.5</span></label><input type="range" id="congSlider" min="0" max="1" step="0.01" value="0.5"></div>
        <div class="slider-group"><label>航线偏好:</label><select id="routePref"><option value="cost">成本优先</option><option value="time">时效优先</option></select></div>
        <button id="runDeepSim" class="btn-primary">运行AI推演</button>
        <div id="deepResult" class="live-metric" style="margin-top:16px;">上海港成本: $5800, 宁波港成本: $5200<br>AI推荐: 宁波港转运</div>
        <div id="routeAdvice"></div></div>`;
        document.getElementById('dynamicContent').innerHTML = html;
        const slider = document.getElementById('congSlider');
        const resultDiv = document.getElementById('deepResult');
        const runBtn = document.getElementById('runDeepSim');
        function updateSim() {
            let coeff = parseFloat(slider.value);
            document.getElementById('congVal').innerText = coeff;
            let res = runDeepSandbox(coeff, document.getElementById('routePref').value);
            resultDiv.innerHTML = `上海港成本: $${res.shCost} , 宁波港成本: $${res.nbCost}<br>🧠 ${res.recommendation}`;
        }
        slider.addEventListener('input', updateSim);
        runBtn.addEventListener('click', updateSim);
        updateSim();
    }
