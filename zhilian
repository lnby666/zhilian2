    function renderDecisionSandbox() {
        const html = `<h2>🧪 决策沙盒 · 压力测试</h2><div class="card"><div class="slider-group"><label>货量(万TEU): <span id="sandVolVal">150</span></label><input type="range" id="sandVol" min="50" max="350" value="150"></div><div class="slider-group"><label>汇率波动(%): <span id="sandFxVal">0</span></label><input type="range" id="sandFx" min="-8" max="12" value="0"></div><div class="slider-group"><label>拥堵天数: <span id="sandDelayVal">0</span></label><input type="range" id="sandDelay" min="0" max="18" value="0"></div><div class="slider-group"><label>海运费暴涨(%): <span id="sandFreightVal">0</span></label><input type="range" id="sandFreight" min="0" max="200" value="0"></div><div class="sandbox-result" id="sandResult">成本: ¥12,450万 | 利润: +5.7%</div></div>`;
