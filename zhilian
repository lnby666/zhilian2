    function updateQuickSandbox() {
        let vol = parseFloat(document.getElementById('quickVol').value);
        let fx = parseFloat(document.getElementById('quickFx').value);
        let delay = parseFloat(document.getElementById('quickDelay').value);
        let freight = parseFloat(document.getElementById('quickFreight').value);
