    document.getElementById('notificationBell').addEventListener('click', (e) => { e.stopPropagation(); const d = document.getElementById('notificationDropdown'); d.style.display = d.style.display === 'block' ? 'none' : 'block'; });
    document.addEventListener('click', () => document.getElementById('notificationDropdown').style.display = 'none');
</script>
