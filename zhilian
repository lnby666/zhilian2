        <div class="card"><h4>⚡ 快速AI归类</h4><input id="quickGoods" placeholder="商品名称 (锂电池/光伏组件/智能机械)"><button id="quickBtn" class="btn-primary">归类</button><div id="quickResult"></div></div>
