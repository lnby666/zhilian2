        if(route === 'seasia') { baseTime = 11.8; baseCost *= 0.94; profitRatio += 1.2; }
        else if(route === 'europe') { baseTime = 18.5; baseCost *= 1.08; profitRatio -= 1.5; }
        let totalCost = baseCost * (1 + freight/100) + delay * 290;
        profitRatio = profitRatio - (fx/2.5) - (delay/6);
        document.getElementById('quickSandboxResult').innerHTML = `总成本: ¥${Math.round(totalCost).toLocaleString()}万<br>运输时效: ${baseTime.toFixed(1)}天<br>预期利润: ${profitRatio>0?'+':''}${profitRatio.toFixed(1)}%`;
    }
    ['quickVol','quickFx','quickDelay','quickFreight','quickRoute'].forEach(id => document.getElementById(id).addEventListener('input', updateQuickSandbox));
    updateQuickSandbox();

    const modules = { home: renderHome, order: renderOrder, warehouse: renderWarehouse, transport: renderTransport, customs: renderCustoms, finance: renderFinance, decision_sandbox: renderDecisionSandbox, basic_data: renderBasicData, service: renderService };
    window.renderModule = function(mod) { if(modules[mod]) modules[mod](); document.querySelectorAll('.menu-item').forEach(it => { if(it.dataset.module === mod) it.classList.add('active'); else it.classList.remove('active'); }); if(mod !== 'home') stopGlobe(); };
    document.querySelectorAll('.menu-item').forEach(item => item.addEventListener('click', () => window.renderModule(item.dataset.module)));
    window.renderModule('home');
    updateNotifBadge();
