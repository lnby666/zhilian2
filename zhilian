    function renderTransport() {
        const html = `<h2>🚚 运输监控</h2><div class="card"><table><thead><tr><th>船名/航次</th><th>航线</th><th>预计到港</th><th>状态</th></tr></thead><tbody>${transports.map(t => `<tr><td>${t.vessel}</td><td>${t.route}</td><td>${t.eta}</td><td>${t.status}</td></tr>`).join('')}</tbody></table><button class="btn" onclick="alert('模拟新增运输')">+ 模拟新增</button></div>`;
