    function renderCustoms() {
        const html = `<h2>📄 报关作业 · AI智能归类</h2><div class="card"><input id="hsGoods" placeholder="商品名称"><button id="hsBtn" class="btn-primary">AI归类</button><div id="hsResult" class="live-metric" style="margin-top:16px;"></div><button class="btn" onclick="alert('模拟报关单已生成')">生成模拟报关单</button></div>`;
