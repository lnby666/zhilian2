<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>智链全球 · 跨境贸易AI决策系统 | 长三角数智枢纽（融合版）</title>
    <!-- Google Fonts & Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <!-- Three.js核心及扩展 -->
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.128.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.128.0/examples/jsm/"
            }
        }
    </script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: radial-gradient(circle at 20% 30%, #0a0f1e, #03060c);
            min-height: 100vh;
            padding: 20px;
        }

        /* 主系统框架 */
        .system-wrapper {
            max-width: 1600px;
            margin: 0 auto;
            background: rgba(6, 14, 24, 0.75);
            backdrop-filter: blur(12px);
            border-radius: 32px;
            border: 1px solid rgba(0, 230, 255, 0.4);
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
        }
        .navbar {
            padding: 16px 28px;
            background: rgba(2, 12, 24, 0.8);
            border-bottom: 1px solid rgba(0, 255, 255, 0.3);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }
        .logo {
            font-weight: 800;
            font-size: 1.4rem;
            background: linear-gradient(135deg, #fff, #00e0ff);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .badge-version {
            background: rgba(0, 200, 255, 0.25);
            padding: 4px 14px;
            border-radius: 40px;
            font-size: 0.7rem;
            color: #aaffff;
        }
        .notification-area {
            position: relative;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 20px;
        }
        .notification-bell {
            position: relative;
            color: #eef;
        }
        .notification-badge {
            position: absolute;
            top: -8px;
            right: -12px;
            background: #ef4444;
            color: white;
            border-radius: 30px;
            padding: 2px 8px;
            font-size: 10px;
        }
        .notification-dropdown {
            position: absolute;
            right: 0;
            top: 40px;
            width: 340px;
            background: rgba(10, 20, 35, 0.98);
            backdrop-filter: blur(12px);
            border-radius: 20px;
            border: 1px solid cyan;
            z-index: 200;
            display: none;
            max-height: 400px;
            overflow-y: auto;
            color: #eef;
        }
        .main-layout {
            display: flex;
            min-height: 680px;
        }
        /* 左侧菜单 + 快速沙盒面板 */
        .sidebar {
            width: 300px;
            background: rgba(0, 10, 20, 0.6);
            backdrop-filter: blur(4px);
            border-right: 1px solid rgba(0, 255, 255, 0.25);
            padding: 20px 0;
            display: flex;
            flex-direction: column;
        }
        .menu-item {
            padding: 12px 24px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 14px;
            color: #c4e0ff;
            transition: 0.2s;
            font-weight: 500;
            font-size: 0.95rem;
        }
        .menu-item i { width: 24px; color: #6cb4ff; }
        .menu-item.active {
            background: linear-gradient(90deg, rgba(0, 150, 255, 0.25), transparent);
            color: #ffffff;
            border-left: 3px solid #0ff;
            text-shadow: 0 0 4px cyan;
        }
        .sandbox-quick {
            margin: 16px 16px 0 16px;
            padding: 16px;
            background: rgba(0, 40, 60, 0.7);
            border-radius: 24px;
            border: 1px solid cyan;
        }
        .sandbox-quick h4 {
            color: #0ff;
            margin-bottom: 12px;
        }
        .slider-group {
            margin: 12px 0;
            font-size: 0.8rem;
        }
        .slider-group label {
            display: block;
            margin-bottom: 4px;
            color: #bbd4ff;
        }
        input[type="range"], select {
            width: 100%;
            background: rgba(0, 20, 40, 0.8);
            border: 1px solid rgba(0, 255, 255, 0.5);
            border-radius: 30px;
            padding: 6px 10px;
            color: white;
        }
        .sandbox-result {
            background: rgba(0, 0, 0, 0.5);
            border-radius: 16px;
            padding: 8px;
            margin-top: 12px;
            font-size: 0.75rem;
            text-align: center;
        }
        .content-panel {
            flex: 1;
            padding: 24px 28px;
            overflow-y: auto;
            max-height: calc(100vh - 100px);
            color: #f0f5ff;
        }
        .card {
            background: rgba(12, 22, 35, 0.85);
            backdrop-filter: blur(8px);
            border-radius: 24px;
            padding: 20px;
            margin-bottom: 24px;
            border: 1px solid rgba(0, 200, 255, 0.35);
            transition: 0.2s;
        }
        .stats {
            display: flex;
            gap: 20px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        .stat {
            flex: 1;
            background: rgba(0, 20, 40, 0.75);
            border-radius: 24px;
            padding: 20px;
            text-align: center;
            border: 1px solid rgba(0, 255, 255, 0.35);
        }
        .region-row {
            display: flex;
            gap: 24px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }
        .map-container {
            flex: 2;
            background: #03060c;
            border-radius: 28px;
            padding: 0;
            border: 1px solid #1e3a5f;
            min-height: 400px;
            overflow: hidden;
            position: relative;
        }
        .live-panel {
            flex: 1;
            background: rgba(10, 20, 35, 0.8);
            border-radius: 28px;
            padding: 20px;
            border: 1px solid rgba(0, 255, 255, 0.4);
        }
        .live-metric {
            margin: 18px 0;
            padding: 12px;
            background: rgba(0, 50, 80, 0.5);
            border-radius: 20px;
        }
        .metric-value {
            font-size: 28px;
            font-weight: 800;
            color: #0ff;
            text-shadow: 0 0 5px cyan;
        }
        .btn {
            padding: 8px 20px;
            border-radius: 40px;
            background: rgba(30, 50, 70, 0.9);
            border: 1px solid cyan;
            color: white;
            cursor: pointer;
            transition: 0.2s;
        }
        .btn-primary {
            background: linear-gradient(95deg, #0066cc, #00a3cc);
            border: none;
        }
        table { width: 100%; border-collapse: collapse; color: #f0f5ff; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid rgba(0, 255, 255, 0.25); }
        th { color: #aaffff; }
        input, select { background: rgba(0, 20, 40, 0.8); border: 1px solid rgba(0, 255, 255, 0.5); border-radius: 30px; padding: 8px 12px; color: white; }
        canvas { max-width: 100%; border-radius: 16px; }
        .flex-cards { display: flex; gap: 20px; flex-wrap: wrap; }
    </style>
</head>
<body>
<div class="system-wrapper">
    <div class="navbar">
        <div class="logo"><i class="fas fa-network-wired"></i> 智链全球·跨境决策融合系统 <span class="badge-version">V3.0 长三角极核</span></div>
        <div class="notification-area">
            <div class="notification-bell" id="notificationBell"><i class="fas fa-bell fa-lg"></i><span class="notification-badge" id="notifCount">0</span></div>
            <div><i class="fas fa-user-astronaut"></i> 决策驾驶舱</div>
            <div id="notificationDropdown" class="notification-dropdown"><div style="padding:12px;border-bottom:1px solid cyan;">🔔 实时动态消息</div><div id="notifList"></div></div>
        </div>
    </div>
    <div class="main-layout">
        <div class="sidebar">
            <!-- 快速沙盒模拟面板 (融合 Streamlit 侧边栏) -->
            <div class="sandbox-quick">
                <h4><i class="fas fa-chalkboard-user"></i> 实时沙盒推演</h4>
                <div class="slider-group"><label>📦 出口货量 (万TEU): <span id="quickVolVal">150</span></label><input type="range" id="quickVol" min="50" max="350" value="150" step="5"></div>
                <div class="slider-group"><label>💱 汇率波动 (%): <span id="quickFxVal">0</span></label><input type="range" id="quickFx" min="-8" max="12" value="0" step="1"></div>
                <div class="slider-group"><label>⛴️ 港口拥堵天数: <span id="quickDelayVal">0</span></label><input type="range" id="quickDelay" min="0" max="18" value="0" step="1"></div>
                <div class="slider-group"><label>📈 海运费暴涨 (%): <span id="quickFreightVal">0</span></label><input type="range" id="quickFreight" min="0" max="200" value="0" step="10"></div>
                <div class="slider-group"><label>🚢 航路选择:</label><select id="quickRoute"><option value="yangtze">长三角直达美西</option><option value="seasia">东南亚快线</option><option value="europe">中欧陆海联运</option></select></div>
                <div class="sandbox-result" id="quickSandboxResult">
                    总成本: ¥12,450万<br>运输时效: 14.2天<br>预期利润: +5.7%
                </div>
            </div>
            <div class="menu-item active" data-module="home"><i class="fas fa-tachometer-alt"></i> 沙盒驾驶舱</div>
            <div class="menu-item" data-module="order"><i class="fas fa-file-invoice"></i> 订单处理</div>
            <div class="menu-item" data-module="warehouse"><i class="fas fa-warehouse"></i> 仓储作业</div>
            <div class="menu-item" data-module="transport"><i class="fas fa-truck-fast"></i> 运输监控</div>
            <div class="menu-item" data-module="customs"><i class="fas fa-passport"></i> 报关作业</div>
            <div class="menu-item" data-module="finance"><i class="fas fa-coins"></i> 财务结算</div>
            <div class="menu-item" data-module="decision_sandbox"><i class="fas fa-chart-line"></i> 决策沙盒·压力测试</div>
            <div class="menu-item" data-module="basic_data"><i class="fas fa-database"></i> 基础资料设置</div>
            <div class="menu-item" data-module="service"><i class="fas fa-headset"></i> 客户服务</div>
        </div>
        <div class="content-panel" id="dynamicContent"></div>
    </div>
</div>

<script type="module">
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

    // ---------- 全局变量 ----------
    let scene, camera, renderer, labelRenderer, earthMesh, cloudMesh, starField, animationId;
    let particleLines = [];
    let realtimeInterval;
    let notifications = [
        { id: 1, title: '🚢 上海港创单日吞吐记录', content: '5月8日吞吐量达15.2万TEU', time: new Date().toLocaleTimeString(), read: false },
        { id: 2, title: '📊 汇率波动预警', content: '离岸人民币突破7.20', time: new Date().toLocaleTimeString(), read: false }
    ];
    function updateNotifBadge() {
        const unread = notifications.filter(n => !n.read).length;
        document.getElementById('notifCount').innerText = unread;
        const listDiv = document.getElementById('notifList');
        if(listDiv) listDiv.innerHTML = notifications.map(n => `<div style="padding:12px;border-bottom:1px solid cyan;cursor:pointer;" onclick="window.markAsRead(${n.id})"><b style="color:cyan;">${n.title}</b><div style="font-size:12px;">${n.content}</div><div style="font-size:10px;">${n.time}</div></div>`).join('');
    }
    window.markAsRead = function(id) { let n = notifications.find(n=>n.id===id); if(n) n.read=true; updateNotifBadge(); };
    function addNotif(title, content) { notifications.unshift({ id: Date.now(), title, content, time: new Date().toLocaleTimeString(), read: false }); updateNotifBadge(); }

    // 科技地球初始化（含上海港、宁波港高亮标注）
    function initTechGlobe(containerId) {
        const container = document.getElementById(containerId);
        if(!container) return;
        if(renderer) { if(animationId) cancelAnimationFrame(animationId); if(renderer.domElement) renderer.domElement.remove(); if(labelRenderer?.domElement) labelRenderer.domElement.remove(); }
        const width = container.clientWidth, height = container.clientHeight;
        scene = new THREE.Scene(); scene.background = new THREE.Color(0x010211);
        camera = new THREE.PerspectiveCamera(45, width/height, 0.1, 1000);
        camera.position.set(0, 0.2, 3.8);
        renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(width, height);
        container.innerHTML = ''; container.appendChild(renderer.domElement);
        labelRenderer = new CSS2DRenderer(); labelRenderer.setSize(width, height);
        labelRenderer.domElement.style.position = 'absolute'; labelRenderer.domElement.style.top = '0px'; labelRenderer.domElement.style.left = '0px';
        container.style.position = 'relative'; container.appendChild(labelRenderer.domElement);
        
        const texLoader = new THREE.TextureLoader();
        const earthMap = texLoader.load('https://threejs.org/examples/textures/planets/earth_atmos_2048.jpg');
        const earthSpec = texLoader.load('https://threejs.org/examples/textures/planets/earth_specular_2048.jpg');
        const cloudMap = texLoader.load('https://threejs.org/examples/textures/planets/earth_clouds_1024.png');
        const earthMat = new THREE.MeshPhongMaterial({ map: earthMap, specularMap: earthSpec, shininess: 5 });
        earthMesh = new THREE.Mesh(new THREE.SphereGeometry(1, 128, 128), earthMat);
        scene.add(earthMesh);
        cloudMesh = new THREE.Mesh(new THREE.SphereGeometry(1.008, 128, 128), new THREE.MeshPhongMaterial({ map: cloudMap, transparent: true, opacity: 0.12 }));
        scene.add(cloudMesh);
        
        function makeLabel(lat, lon, name, color='#0ff') {
            const phi = (90 - lat) * Math.PI/180, theta = lon * Math.PI/180;
            const x = 1.06 * Math.sin(phi) * Math.cos(theta), y = 1.06 * Math.cos(phi), z = 1.06 * Math.sin(phi) * Math.sin(theta);
            const div = document.createElement('div'); div.textContent = name;
            div.style.cssText = `color:${color};font-size:18px;font-weight:bold;text-shadow:0 0 12px cyan;background:rgba(0,0,0,0.7);padding:4px 16px;border-radius:40px;border:2px solid ${color};backdrop-filter:blur(8px);`;
            const label = new CSS2DObject(div); label.position.set(x, y, z); scene.add(label);
            const marker = new THREE.Mesh(new THREE.SphereGeometry(0.06, 16, 16), new THREE.MeshStandardMaterial({ color, emissive: color, emissiveIntensity: 0.9 }));
            marker.position.set(x, y, z); scene.add(marker);
        }
        makeLabel(31.23, 121.47, '🌟 上海港 (全球第一)', '#0ff');
        makeLabel(29.86, 121.54, '⚓ 宁波舟山港 (货物吞吐第一)', '#0ff');
        // 粒子流
        const startPos = { x: 1.04 * Math.sin((90-31.23)*Math.PI/180)*Math.cos(121.47*Math.PI/180), y: 1.04*Math.cos((90-31.23)*Math.PI/180), z: 1.04*Math.sin((90-31.23)*Math.PI/180)*Math.sin(121.47*Math.PI/180) };
        const targets = [[34.05, -118.24], [53.55, 9.99], [1.35, 103.87]];
        for(let i=0;i<80;i++) {
            const t = targets[i%3]; const phiT = (90 - t[0])*Math.PI/180, thetaT = t[1]*Math.PI/180;
            const endPos = { x: 1.04*Math.sin(phiT)*Math.cos(thetaT), y: 1.04*Math.cos(phiT), z: 1.04*Math.sin(phiT)*Math.sin(thetaT) };
            const particle = new THREE.Mesh(new THREE.SphereGeometry(0.008, 6,6), new THREE.MeshStandardMaterial({ color: 0xffaa44, emissive: 0x442200 }));
            scene.add(particle);
            particleLines.push({ obj: particle, start: startPos, end: endPos, progress: Math.random(), speed: 0.003+Math.random()*0.006 });
        }
        const starGeo = new THREE.BufferGeometry();
        const starPositions = []; for(let i=0;i<1800;i++) starPositions.push((Math.random()-0.5)*2000, (Math.random()-0.5)*1000, (Math.random()-0.5)*300-80);
        starGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(starPositions), 3));
        starField = new THREE.Points(starGeo, new THREE.PointsMaterial({ color: 0xffffff, size: 0.2 }));
        scene.add(starField);
        const ambient = new THREE.AmbientLight(0x404060), dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
        dirLight.position.set(5, 3, 5); scene.add(ambient); scene.add(dirLight);
        
        function animate() {
            animationId = requestAnimationFrame(animate);
            if(earthMesh) earthMesh.rotation.y += 0.0015;
            if(cloudMesh) cloudMesh.rotation.y += 0.0018;
            if(starField) starField.rotation.y += 0.0003;
            particleLines.forEach(p => { p.progress += p.speed; if(p.progress>=1) p.progress=0; const x = p.start.x+(p.end.x-p.start.x)*p.progress; const y = p.start.y+(p.end.y-p.start.y)*p.progress; const z = p.start.z+(p.end.z-p.start.z)*p.progress; p.obj.position.set(x,y,z); });
            renderer.render(scene, camera); if(labelRenderer) labelRenderer.render(scene, camera);
        }
        animate();
        window.addEventListener('resize', () => { if(container) { const w = container.clientWidth, h = container.clientHeight; renderer.setSize(w, h); labelRenderer.setSize(w, h); camera.aspect = w/h; camera.updateProjectionMatrix(); } });
    }
    function stopGlobe() { if(animationId) cancelAnimationFrame(animationId); if(renderer) renderer.dispose(); }

    // ---------- 业务模块渲染 ----------
    let orders = [{ id:'PO10001', customer:'Amazon EU', dest:'汉堡', value:124500, status:'已报关' }, { id:'PO10002', customer:'DHL', dest:'洛杉矶', value:87600, status:'运输中' }];
    let warehouses = [{ name:'上海洋山仓', occupancy:82, days:28 }, { name:'宁波北仑仓', occupancy:68, days:35 }, { name:'苏州高新仓', occupancy:45, days:22 }];
    let transports = [{ vessel:'EVER FORTUNE', route:'上海-洛杉矶', eta:'2025-05-15', status:'航行中' }];
    let customers = [{ name:'DHL Global', credit:'AA' }, { name:'Amazon EU', credit:'A+' }];
    let suppliers = [{ name:'苏州华兴源创', product:'智能控制器', leadTime:'7天' }];
    let tickets = [{ id:'TK001', customer:'苏州电子', issue:'归类咨询', status:'处理中' }];
    
    function renderHome() {
        const html = `<div><div style="display:flex; justify-content:space-between;"><h2><i class="fas fa-globe-asia"></i> 地球网络·长三角跨境决策驾驶舱</h2><div class="counter">动态模拟</div></div>
        <div class="region-row"><div class="map-container" id="globeHome" style="height: 400px;"></div><div class="live-panel"><h3><i class="fas fa-chart-line"></i> 实时动态监测</h3>
            <div class="live-metric"><div class="metric-title">上海港实时吞吐量 (TEU)</div><div class="metric-value" id="liveShanghai">142,300</div></div>
            <div class="live-metric"><div class="metric-title">宁波舟山港拥堵指数</div><div class="metric-value" id="congestionIdx">0.62</div></div>
            <div class="live-metric"><div class="metric-title">全球贸易晴雨表</div><div class="metric-value" id="globalTrade">289.4</div></div>
        </div></div>
        <div class="stats"><div class="stat"><div>待处理订单</div><div>32</div></div><div class="stat"><div>在途货柜</div><div>129</div></div><div class="stat"><div>沙盒模拟次数</div><div>47</div></div></div>
        <div class="card"><input id="quickGoods" placeholder="商品AI预归类: 输入智能机械/锂电池/光伏组件"><button id="quickBtn" class="btn-primary">AI归类</button><div id="quickResult" class="live-metric" style="margin-top:12px;"></div></div>
        <div class="flex-cards"><div class="card"><h4>🚀 快速决策入口</h4><button class="btn-primary" onclick="window.renderModule('decision_sandbox')">进入压力测试沙盒</button></div><div class="card"><h4>📊 长三角供应链月报</h4><div>上海港效率+7% | 宁波舟山新增航线</div></div></div>`;
        document.getElementById('dynamicContent').innerHTML = html;
        setTimeout(() => { initTechGlobe('globeHome'); }, 50);
        if(realtimeInterval) clearInterval(realtimeInterval);
        realtimeInterval = setInterval(() => {
            let sh = (138000 + Math.floor(Math.random() * 8000)).toLocaleString();
            let cong = (0.55 + Math.random()*0.2).toFixed(2);
            let trade = (285 + Math.random()*12).toFixed(1);
            if(document.getElementById('liveShanghai')) document.getElementById('liveShanghai').innerText = sh;
            if(document.getElementById('congestionIdx')) document.getElementById('congestionIdx').innerText = cong;
            if(document.getElementById('globalTrade')) document.getElementById('globalTrade').innerText = trade;
        }, 4000);
        document.getElementById('quickBtn')?.addEventListener('click', () => {
            const goods = document.getElementById('quickGoods').value;
            const map = {'智能机械':'HS8479.89, 低风险', '锂电池':'HS8507.60 危品注意', '光伏组件':'HS8541.43 低碳'};
            const res = map[goods] || '请详细填写商品描述';
            document.getElementById('quickResult').innerHTML = `<i class="fas fa-microchip"></i> AI归类: ${res}`;
        });
    }
    function renderOrder() {
        const html = `<h2>📋 订单处理</h2><div class="card"><button class="btn btn-primary" onclick="window.addOrder()">+ 新增模拟订单</button><table><thead><tr><th>订单号</th><th>客户</th><th>目的地</th><th>货值(USD)</th><th>状态</th></tr></thead><tbody id="orderTableBody"></tbody></table></div>`;
        document.getElementById('dynamicContent').innerHTML = html;
        const tbody = document.getElementById('orderTableBody');
