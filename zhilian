<script type="module">
    import * as THREE from 'three';
    import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

    // ---------- 全局状态与实时数据 ----------
    let globalState = {
        exchangeRate: 7.185,        // USD/CNY
        weather: { shanghai: "多云", ningbo: "小雨", temp: 18 },
