    // 辅助函数：更新通知UI
    function updateNotifBadge() {
        const unread = notifications.filter(n => !n.read).length;
        document.getElementById('notifCount').innerText = unread;
        const listDiv = document.getElementById('notifList');
        if(listDiv) listDiv.innerHTML = notifications.map(n => `<div style="padding:12px;border-bottom:1px solid cyan;cursor:pointer;" onclick="markAsRead(${n.id})"><b style="color:cyan;">${n.title}</b><div style="font-size:12px;">${n.content}</div><div style="font-size:10px;">${n.time}</div></div>`).join('');
    }
    window.markAsRead = function(id) { let n = notifications.find(n=>n.id===id); if(n) n.read=true; updateNotifBadge(); };
    function addNotif(title, content) { notifications.unshift({ id: Date.now(), title, content, time: new Date().toLocaleTimeString(), read: false }); updateNotifBadge(); }
    
    // ---------- 实时数据API接入 ----------
    // 汇率API (exchangerate.host 免费无需key)
    async function fetchExchangeRate() {
        try {
            const res = await fetch('https://api.exchangerate.host/latest?base=USD&symbols=CNY');
            const data = await res.json();
            if(data.rates && data.rates.CNY) {
                globalState.exchangeRate = data.rates.CNY;
                document.getElementById('liveRate') && (document.getElementById('liveRate').innerText = globalState.exchangeRate.toFixed(4));
            }
        } catch(e) { console.warn("汇率API失败，使用模拟值"); }
    }
    // 天气API (OpenWeatherMap需要API key，这里使用wttr.in的免费文本接口)
    async function fetchWeather() {
        try {
            const shRes = await fetch('https://wttr.in/Shanghai?format=%C+%t');
            const shText = await shRes.text();
            const parts = shText.split(' ');
            globalState.weather.shanghai = parts[0] || "多云";
            globalState.weather.temp = parseInt(parts[1]?.replace('+','')) || 18;
            document.getElementById('weatherShanghai') && (document.getElementById('weatherShanghai').innerText = `${globalState.weather.shanghai} ${globalState.weather.temp}°C`);
        } catch(e) { console.warn("天气API失败"); }
    }
    // 模拟港口吞吐压力数据 (真实场景可接入AIS数据，此处动态模拟)
    function updatePortCongestion() {
        // 模拟实时变化
        globalState.portCongestion = {
            yangshan: 0.5 + Math.random() * 0.4,
            waigaoqiao: 0.4 + Math.random() * 0.4,
            ningbo: 0.6 + Math.random() * 0.3
        };
        // 更新柱状图
        updatePortBars();
        // 触发AI避险建议（基于拥堵）
        checkCongestionAlert();
    }
    function updatePortBars() {
        const yangshanBar = document.getElementById('yangshanBar');
        const waigaoBar = document.getElementById('waigaoBar');
        const ningboBar = document.getElementById('ningboBar');
        if(yangshanBar) yangshanBar.style.width = `${globalState.portCongestion.yangshan * 100}%`;
        if(waigaoBar) waigaoBar.style.width = `${globalState.portCongestion.waigaoqiao * 100}%`;
        if(ningboBar) ningboBar.style.width = `${globalState.portCongestion.ningbo * 100}%`;
        // 修改颜色
        const setBarColor = (el, value) => { if(el) el.className = `port-bar ${value>0.7?'red-bar':(value>0.5?'yellow-bar':'green-bar')}`; };
        setBarColor(document.getElementById('yangshanBarColor'), globalState.portCongestion.yangshan);
        setBarColor(document.getElementById('waigaoBarColor'), globalState.portCongestion.waigaoqiao);
        setBarColor(document.getElementById('ningboBarColor'), globalState.portCongestion.ningbo);
    }
    function checkCongestionAlert() {
        if(globalState.portCongestion.ningbo > 0.75) {
            addNotif("⚠️ 宁波舟山港拥堵预警", "当前拥堵系数超过0.75，建议考虑分流至上海港");
        }
        if(globalState.portCongestion.yangshan > 0.8) {
            addNotif("⚠️ 洋山港重度拥堵", "预计船舶等泊时间增加12小时");
        }
